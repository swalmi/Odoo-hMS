<odoo>
    <record id="view_patient_form_v2" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <field name="first_name"/>
                        <field name="last_name"/>
                        <label for="birth_date" string="Age / Date of Birth"/>
                        <div class="o_row">
                            <field name="birth_date" placeholder="Pick Date of Birth"/>
                            <span class="oe_inline"> (Age: </span>
                            <field name="age" readonly="1" class="oe_inline"/>
                            <span class="oe_inline">)</span>
                        </div>

                        <field name="department_id"
                               domain="[('is_opened','=',True)]"/>

                        <field name="department_capacity" readonly="1"/>

                        <!-- REQUIRED FOR ODOO 17 MODIFIERS -->
                        <field name="is_department_selected" invisible="1"/>
                        <field name="is_old_patient" invisible="1"/>
                    </group>

                    <group>
                        <field name="doctor_id"
                               readonly="not is_department_selected"/>
                    </group>

                    <group>
                        <field name="pcr"/>
                        <field name="cr_ratio" required="pcr"/>
                    </group>

                    <group>
                        <field name="history"
                               invisible="not is_old_patient"/>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
